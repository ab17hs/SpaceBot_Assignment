# Space Bot — environment template
#
# Copy this file to ".env" (no extension prefix) and fill in your real keys.
# The real .env is excluded by .gitignore so it will NOT be committed.
#
# To create the .env file on Windows:
#     copy .env.example .env
#
# Then open .env in a text editor and replace the placeholders below.

# Personal access token from https://developer.webex.com/docs/getting-started
WEBEX_TOKEN=replace-me-with-your-real-webex-token

# Mapbox access token from https://account.mapbox.com/access-tokens
GEOCODE_API_KEY=replace-me-with-your-real-mapbox-token
